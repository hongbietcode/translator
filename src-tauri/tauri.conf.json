{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Translator",
    "version": "0.1.0",
    "identifier": "com.translator.dev",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:5173",
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build"
    },
    "app": {
        "macOSPrivateApi": true,
        "windows": [
            {
                "label": "main",
                "title": "Translator",
                "width": 600,
                "height": 400,
                "minWidth": 400,
                "minHeight": 200,
                "center": true,
                "transparent": true,
                "decorations": false,
                "alwaysOnTop": true,
                "resizable": true,
                "skipTaskbar": false
            }
        ],
        "security": {
            "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' ipc://localhost http://localhost:3456 wss: https:; img-src 'self' data:"
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "macOS": {
            "entitlements": "Entitlements.plist",
            "frameworks": [],
            "minimumSystemVersion": "13.0"
        }
    }
}
